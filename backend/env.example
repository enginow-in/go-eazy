# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string — works with a local Postgres install or a
# Supabase project's connection string (Project Settings -> Database).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goeazy

# Long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Razorpay keys (Dashboard -> Settings -> API Keys). Test-mode keys start
# with rzp_test_ and are safe to use while developing.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

PORT=3000
NODE_ENV=development
